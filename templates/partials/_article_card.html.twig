{# Renders one article preview card. Expects `article`. #}
{% set accent = {
    'AI Engineering': 'bg-brand-violet',
    'Platform Engineering': 'bg-brand-blue',
    'Cloud Economics': 'bg-brand-lime',
    'Architecture': 'bg-brand-pink',
}[article.category]|default('bg-slatey-400') %}

<a href="{{ path('article', { slug: article.slug }) }}"
   class="group flex flex-col rounded-2xl border border-slatey-200 bg-white p-6 shadow-card transition-all duration-200 hover:-translate-y-0.5 hover:border-slatey-300 hover:shadow-card-hover">
    <div class="mb-4 flex items-center justify-between">
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-slatey-600">
            <span class="h-2 w-2 rounded-full {{ accent }}"></span>
            {{ article.category }}
        </span>
        <span class="text-xs text-slatey-400">{{ article.readingTime }} min read</span>
    </div>

    <h3 class="font-display text-xl font-bold leading-snug tracking-tight text-ink-950 transition-colors group-hover:text-brand-blue">
        {{ article.title }}
    </h3>
    <p class="mt-2.5 line-clamp-3 flex-1 text-sm leading-relaxed text-slatey-500">
        {{ article.description }}
    </p>

    <div class="mt-6 flex items-center gap-3 border-t border-slatey-100 pt-4">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-ink-950 text-[11px] font-semibold text-white">
            {{ article.authorInitials }}
        </span>
        <div class="text-xs leading-tight">
            <p class="font-medium text-ink-950">{{ article.author }}</p>
            <p class="text-slatey-400">{{ article.date|date('M j, Y') }}</p>
        </div>
    </div>
</a>
